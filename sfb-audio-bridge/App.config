<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!--
      ═══════════════════════════════════════════════════════════
      SfB UCMA Trusted Application Ayarlari
      ═══════════════════════════════════════════════════════════

      Bu degerleri SfB Management Shell ciktilariyla doldur:
        Get-CsTrustedApplication
        Get-CsTrustedApplicationPool
        Get-CsTrustedApplicationEndpoint
    -->

    <!-- Trusted Application ID — SfB Topology'de kayitli isim -->
    <add key="Sfb.ApplicationId" value="sfb-audio-bridge" />

    <!-- Trusted Application Pool FQDN -->
    <add key="Sfb.TrustedPoolFqdn" value="sfb-audio-pool.yourdomain.com" />

    <!-- Trusted Application Port — New-CsTrustedApplication -Port ile verilen deger -->
    <add key="Sfb.TrustedPort" value="8443" />

    <!-- Application Endpoint GRUU (Contact URI)
         Get-CsTrustedApplicationEndpoint ile alinir -->
    <add key="Sfb.EndpointGruu" value="sip:sfb-audio-bridge@yourdomain.com;gruu;opaque=srvr:sfb-audio-bridge:AAAAAA" />

    <!-- SfB Registrar FQDN -->
    <add key="Sfb.RegistrarFqdn" value="sfbfe01.yourdomain.com" />
    <add key="Sfb.RegistrarPort" value="5061" />

    <!-- SSL Sertifika Subject Name (makine sertifikasi) -->
    <add key="Sfb.CertificateSubject" value="sfb-audio-pool.yourdomain.com" />

    <!--
      ═══════════════════════════════════════════════════════════
      Spring Boot WebSocket Baglanti Ayarlari
      ═══════════════════════════════════════════════════════════
    -->
    <add key="Spring.WebSocketUrl" value="ws://spring-server.yourdomain.com:8480/ws/audio-stream" />

    <!-- Baglanti koptiginda yeniden deneme -->
    <add key="Spring.ReconnectMaxRetries" value="10" />
    <add key="Spring.ReconnectDelayMs" value="5000" />

    <!--
      ═══════════════════════════════════════════════════════════
      Audio Ayarlari
      ═══════════════════════════════════════════════════════════
    -->

    <!-- Hangi conference URI'leri dinlenecek — bos ise tum incoming invitation'lar kabul edilir -->
    <add key="Audio.AutoJoinConferences" value="true" />

    <!-- Kayit dizini (opsiyonel — WAV olarak da yerel kayit tutmak istersen) -->
    <add key="Audio.LocalRecordingDir" value="C:\SfbRecordings" />
    <add key="Audio.EnableLocalRecording" value="false" />
  </appSettings>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>
